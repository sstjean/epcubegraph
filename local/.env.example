# EP Cube Graph — Local Ingestion Stack Configuration
# Copy this file to .env and fill in your values

# EP Cube Cloud API credentials (for epcube-exporter)
EPCUBE_USERNAME=your-email@example.com
EPCUBE_PASSWORD=your-epcube-password

# Emporia Vue Cloud API credentials (optional — omit to skip Vue polling)
EMPORIA_USERNAME=your-emporia-email@example.com
EMPORIA_PASSWORD=your-emporia-password
