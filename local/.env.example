# EP Cube Graph — Local Ingestion Stack Configuration
# Copy this file to .env and fill in your values

# echonet-exporter: EP Cube gateway IP addresses on the LAN
# Each gateway exposes both storage_battery and home_solar ECHONET Lite classes
# at the same IP address. Set both gateway IPs below.

# Gateway 1 (e.g., EP Cube 1.0)
EPCUBE1_IP=192.168.1.10

# Gateway 2 (e.g., EP Cube 2.0)
EPCUBE2_IP=192.168.1.11

# vmagent: Remote-write target (Azure-hosted VictoriaMetrics via vmauth)
REMOTE_WRITE_URL=https://epcubegraph-vm.<region>.azurecontainerapps.io/api/v1/write
REMOTE_WRITE_TOKEN=<token-from-azure-key-vault>
